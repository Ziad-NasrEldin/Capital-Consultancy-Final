# Database Configuration (PostgreSQL)
DB_USER=crm_user
DB_PASSWORD=changeme_secure_password
DB_NAME=crm_db
DATABASE_URL=postgresql://crm_user:changeme_secure_password@postgres:5432/crm_db

# Next.js Configuration
NODE_ENV=production

# Authentication (optional, if you implement auth later)
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://yourdomain.com

# API Configuration
API_BASE_URL=https://yourdomain.com
