server {
    listen 80;
    server_name glasses.mavoid.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name glasses.mavoid.com;

    ssl_certificate /etc/letsencrypt/live/glasses.mavoid.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/glasses.mavoid.com/privkey.pem;

    location / {
        proxy_pass http://localhost:8606;  # Docker's HTTPS port
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}