# =============================================================================
# 44 Mashraba ST - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain / URLs
# -----------------------------------------------------------------------------
# Your domain name (without protocol)
APP_HOST=44-mashraba-st.mavoid.com

# Full frontend URL (used by Rails CORS and mailer links)
FRONTEND_URL=https://44-mashraba-st.mavoid.com

# API base URL used by the frontend at build time (must include /api suffix)
VITE_API_URL=https://44-mashraba-st.mavoid.com/api

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=q3y4JVbJWbsm39d2
POSTGRES_DB=44_mashraba_st

# DATABASE_URL used by Rails (must match the credentials above)
# Note: special characters in the password must be URL-encoded (e.g. @ → %40)
# The hostname "postgres" refers to the docker-compose service name
DATABASE_URL=postgresql://postgres:q3y4JVbJWbsm39d2@postgres:5432/44_mashraba_st

# -----------------------------------------------------------------------------
# Rails Secrets
# -----------------------------------------------------------------------------
# Generate with: docker compose run --rm backend bin/rails secret
SECRET_KEY_BASE=68f6d979ec98e02ad97ffc0f60438d30a6002d08dac4a407f09605d5e74d7328f93bf7a4c3c3c1f213445549cf8134a1fe12725304ad217d3063329c33bb33b2
DEVISE_JWT_SECRET_KEY=3f914e4948ffe15865f99023ff318eda

# From config/master.key (only needed if using Rails encrypted credentials)
# RAILS_MASTER_KEY=

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Resend email API key (https://resend.com)
RESEND_API_KEY=re_8Pziu6WC_6gkNLe8gwvwUu5LJSVDbvYFH

# -----------------------------------------------------------------------------
# Host Port Mapping (change if defaults conflict with other apps on the VPS)
