# =============================================================================
# 44 Mashraba ST - Host Nginx Configuration
# =============================================================================
# Place this file at: /etc/nginx/sites-available/44-mashraba-st.conf
# Then symlink:       ln -s /etc/nginx/sites-available/44-mashraba-st.conf /etc/nginx/sites-enabled/
# Test config:        nginx -t
# Reload:             systemctl reload nginx
#
# Prerequisites:
#   - Obtain SSL certs first (see certbot section below)
#   - Docker containers must be running
# =============================================================================

# Backend API (Thruster on container port 80  host port 3677)
upstream 44_mashraba_st_backend {
    server 127.0.0.1:3767;
    keepalive 32;
}

# Frontend (nginx on container port 80  host port 3537)
upstream 44_mashraba_st_frontend {
    server 127.0.0.1:3735;
    keepalive 32;
}

# --- HTTP  HTTPS redirect ---------------------------------------------------
server {
    listen 80;
    listen [::]:80;
    server_name 44-mashraba-st.mavoid.com;

    # Let Certbot handle ACME challenges
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# --- Main HTTPS server --------------------------------------------------------
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name 44-mashraba-st.mavoid.com;

    # ---- SSL -----------------------------------------------------------------
    ssl_certificate     /etc/letsencrypt/live/44-mashraba-st.mavoid.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/44-mashraba-st.mavoid.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

    # ---- Security headers ----------------------------------------------------
    add_header X-Frame-Options        "SAMEORIGIN"                always;
    add_header X-Content-Type-Options "nosniff"                   always;
    add_header X-XSS-Protection       "1; mode=block"             always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;

    # ---- Logging -------------------------------------------------------------
    access_log /var/log/nginx/44-mashraba-st-access.log;
    error_log  /var/log/nginx/44-mashraba-st-error.log;

    # ---- General settings ----------------------------------------------------
    client_max_body_size 50M;

    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types
        text/plain text/css text/xml text/javascript
        application/javascript application/json application/xml+rss
        application/rss+xml font/truetype font/opentype
        application/vnd.ms-fontobject image/svg+xml;

    # ==========================================================================
    #  Backend routes  proxied to the Rails container
    # ==========================================================================

    # API endpoints: /api/v1/*  backend as /v1/*
    location /api/ {
        proxy_pass         http://44_mashraba_st_backend/;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade            $http_upgrade;
        proxy_set_header   Connection         "upgrade";
        proxy_set_header   Host               $host;
        proxy_set_header   X-Real-IP          $remote_addr;
        proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto  $scheme;
        proxy_set_header   X-Forwarded-Host   $host;
        proxy_set_header   X-Forwarded-Port   $server_port;

        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;

        proxy_buffering       on;
        proxy_buffer_size     4k;
        proxy_buffers         8 4k;
        proxy_busy_buffers_size 8k;
    }

    # Devise auth endpoints: /admins/sign_in, /admins/sign_out, etc.
    location /admins/ {
        proxy_pass         http://44_mashraba_st_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host               $host;
        proxy_set_header   X-Real-IP          $remote_addr;
        proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto  $scheme;
        proxy_set_header   X-Forwarded-Host   $host;
        proxy_set_header   X-Forwarded-Port   $server_port;
    }

    # Rails Active Storage files
    location /rails/ {
        proxy_pass         http://44_mashraba_st_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host               $host;
        proxy_set_header   X-Real-IP          $remote_addr;
        proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto  $scheme;
    }

    # ==========================================================================
    #  Frontend  everything else goes to the React SPA
    # ==========================================================================

    location / {
        proxy_pass         http://44_mashraba_st_frontend;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade            $http_upgrade;
        proxy_set_header   Connection         "upgrade";
        proxy_set_header   Host               $host;
        proxy_set_header   X-Real-IP          $remote_addr;
        proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto  $scheme;
        proxy_set_header   X-Forwarded-Host   $host;
        proxy_set_header   X-Forwarded-Port   $server_port;

        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;

        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers     8 4k;
    }

    # Long-lived cache for hashed frontend assets
    location /assets/ {
        proxy_pass http://44_mashraba_st_frontend;
        proxy_cache_valid 200 60m;
        proxy_cache_bypass $http_pragma $http_authorization;
        add_header Cache-Control "public, immutable, max-age=31536000";
    }
}